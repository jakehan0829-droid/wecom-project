# App
APP_NAME=chronic-disease-mvp
APP_HOST=0.0.0.0
APP_PORT=3000
NODE_ENV=production

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=chronic_disease
DB_USER=postgres
DB_PASSWORD=${DB_PASSWORD:-postgres}  # 生产环境请设置强密码

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
# REDIS_PASSWORD=${REDIS_PASSWORD:-}  # 如果Redis需要密码

# JWT
JWT_SECRET=${JWT_SECRET:-replace_me_with_secure_random_string_in_production}  # 生产环境必须设置强随机字符串
JWT_EXPIRES_IN=7d

# WeCom / Agent
WECOM_CORP_ID=${WECOM_CORP_ID:-wwopenclawdemo001}
WECOM_AGENT_ID=${WECOM_AGENT_ID:-1000002}
WECOM_SECRET=${WECOM_SECRET:-demo_secret_123456}
WECOM_TOKEN=${WECOM_TOKEN:-openclaw-demo-token}
WECOM_AES_KEY=${WECOM_AES_KEY:-rs7wJpwNlXFnPLYHWo2q/FzywfBMCK2d0I70Mcvi5mw=}

# AI / OpenAI Codex
AI_PROVIDER=${AI_PROVIDER:-openai-codex}
AI_MODEL=${AI_MODEL:-gpt-5.4}
AI_API_KEY=${AI_API_KEY:-sk-35136ffb95857141c5c2e424b1f4682cc7871bbf448a7af1c0295e5d2fe91735}
AI_BASE_URL=${AI_BASE_URL:-https://www.open1.codes/v1}

# 安全配置说明：
# 1. 生产环境必须设置以下环境变量：
#    - JWT_SECRET: 使用 openssl rand -base64 32 生成
#    - DB_PASSWORD: 强密码
#    - AI_API_KEY: 真实的AI服务API密钥
# 2. 企业微信配置需要替换为真实的corp_id、agent_id和secret
# 3. 可以通过docker-compose.prod.yml的环境变量或Docker运行时的-e参数设置