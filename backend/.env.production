# App
APP_NAME=chronic-disease-mvp
APP_HOST=0.0.0.0
APP_PORT=3000
NODE_ENV=production

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=chronic_disease
DB_USER=postgres
DB_PASSWORD=change_me_strong_password

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
# REDIS_PASSWORD=change_me_if_redis_requires_auth

# JWT — 必须设置强随机字符串，使用: openssl rand -base64 32
JWT_SECRET=change_me_use_openssl_rand_base64_32
JWT_EXPIRES_IN=7d

# 企业微信配置 — 替换为真实的企业微信应用凭证
WECOM_CORP_ID=your_corp_id
WECOM_AGENT_ID=your_agent_id
WECOM_SECRET=your_agent_secret
WECOM_TOKEN=your_callback_token
WECOM_AES_KEY=your_encoding_aes_key

# AI 服务配置
AI_PROVIDER=openai
AI_MODEL=gpt-4o
AI_API_KEY=your_ai_api_key
AI_BASE_URL=https://api.openai.com/v1
