# App
APP_NAME=chronic-disease-mvp
APP_HOST=0.0.0.0
APP_PORT=3000
NODE_ENV=development

# Database (本地开发默认值)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=chronic_disease
DB_USER=postgres
DB_PASSWORD=postgres

# Redis (本地开发默认值)
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# JWT — 开发环境可用任意字符串，生产环境必须用强随机值
# 生成命令: openssl rand -base64 32
JWT_SECRET=dev_secret_change_in_production
JWT_EXPIRES_IN=7d

# 企业微信配置 — 从企业微信管理后台获取
# https://work.weixin.qq.com/wework_admin/frame#apps
WECOM_CORP_ID=your_corp_id
WECOM_AGENT_ID=your_agent_id
WECOM_SECRET=your_agent_secret
WECOM_TOKEN=your_callback_token
WECOM_AES_KEY=your_encoding_aes_key_43chars

# AI 服务配置
# AI_PROVIDER 可选: openai | anthropic | mock
AI_PROVIDER=mock
AI_MODEL=gpt-4o
AI_API_KEY=your_ai_api_key
AI_BASE_URL=https://api.openai.com/v1

# AI自动分析与回复开关
# 设为 false 可关闭自动AI分析（默认开启）
# ENABLE_AI_ANALYSIS=false
