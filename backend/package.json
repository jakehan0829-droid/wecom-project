{
  "name": "chronic-disease-mvp-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/main.ts",
    "start": "node dist/main.js",
    "build": "tsc -p tsconfig.json",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "wecom:cutover:preflight": "bash ../ops/rehearsal/wecom-stable-mapping-cutover/preflight.sh",
    "wecom:cutover:smoke": "bash ../ops/rehearsal/wecom-stable-mapping-cutover/cutover-smoke.sh",
    "wecom:cutover:acceptance": "bash ../ops/rehearsal/wecom-stable-mapping-cutover/generate-acceptance-summary.sh",
    "wecom:cutover:pack": "bash ../ops/rehearsal/wecom-stable-mapping-cutover/run-cutover-pack.sh full",
    "prepare": "husky"
  },
  "dependencies": {
    "@types/uuid": "^11.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "openai": "^4.71.0",
    "pg": "^8.12.0",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.7.4",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
