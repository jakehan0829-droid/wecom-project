{
  "name": "chronic-disease-mvp-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/main.ts",
    "start": "node dist/main.js",
    "build": "tsc -p tsconfig.json",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "wecom:cutover:preflight": "bash ../ops/rehearsal/wecom-stable-mapping-cutover/preflight.sh",
    "wecom:cutover:smoke": "bash ../ops/rehearsal/wecom-stable-mapping-cutover/cutover-smoke.sh",
    "wecom:cutover:acceptance": "bash ../ops/rehearsal/wecom-stable-mapping-cutover/generate-acceptance-summary.sh",
    "wecom:cutover:pack": "bash ../ops/rehearsal/wecom-stable-mapping-cutover/run-cutover-pack.sh full"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.7.4",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
